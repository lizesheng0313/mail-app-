  <div>
    <!-- 页面标题 -->
    <div class="mb-8">
      <h2 class="text-3xl font-bold text-gray-900">个人设置</h2>
      <p class="text-gray-500 mt-2">管理您的账号信息和第三方账号绑定</p>
