<template>
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 加载状态 -->
      <div v-if="loading" class="text-center py-12">
        <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600"></div>
        <p class="mt-4 text-gray-600">加载中...</p>
      </div>

      <!-- 工作流详情 -->
      <div v-else-if="workflow" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- 左侧主要内容 -->
        <div class="lg:col-span-2 space-y-6">
          <!-- 基本信息 -->
          <div class="bg-white rounded-lg shadow p-6">
            <!-- 标题和评分 -->
            <div class="flex justify-between items-start mb-4">
              <h1 class="text-3xl font-bold text-gray-900">{{ workflow.name }}</h1>
              <div class="flex items-center">
                <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <span class="ml-1 text-lg font-semibold">{{ workflow.rating }}</span>
                <span class="ml-1 text-sm text-gray-500">({{ workflow.review_count }} 评价)</span>
              </div>
            </div>

            <!-- 作者信息 -->
            <div class="flex items-center mb-4">
              <img
                :src="workflow.author_avatar || '/default-avatar.png'"
                :alt="workflow.author_name"
                class="h-10 w-10 rounded-full mr-3"
              />
              <div>
                <p class="text-sm font-medium text-gray-900">{{ workflow.author_name }}</p>
                <p class="text-xs text-gray-500">{{ workflow.author_bio }}</p>
              </div>
            </div>

            <!-- 统计信息 -->
            <div class="flex flex-wrap gap-6 mb-6 text-sm text-gray-600">
              <div class="flex items-center">
                <svg class="h-5 w-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                {{ workflow.purchase_count }} 次购买
              </div>
              <div class="flex items-center">
                <svg class="h-5 w-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                {{ workflow.total_calls || 0 }} 次调用
              </div>
              <div class="flex items-center">
                <svg class="h-5 w-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {{ formatDate(workflow.published_at) }} 发布
              </div>
            </div>

            <!-- 描述 -->
            <div class="prose max-w-none">
              <h3 class="text-lg font-semibold mb-2">功能介绍</h3>
              <p class="text-gray-600 whitespace-pre-line">{{ workflow.description }}</p>
            </div>

            <!-- 关键词 -->
            <div v-if="workflow.keywords && workflow.keywords.length > 0" class="mt-4">
              <div class="flex flex-wrap gap-2">
                <span
                  v-for="keyword in workflow.keywords"
                  :key="keyword"
                  class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded-full"
                >
                  {{ keyword }}
                </span>
              </div>
            </div>
          </div>

          <!-- 截图展示 -->
          <div v-if="workflow.screenshots && workflow.screenshots.length > 0" class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold mb-4">界面预览</h3>
            <div class="grid grid-cols-2 gap-4">
              <img
                v-for="(screenshot, index) in workflow.screenshots"
                :key="index"
                :src="screenshot"
                :alt="`截图 ${index + 1}`"
                class="w-full rounded-lg border border-gray-200 cursor-pointer hover:opacity-90"
                @click="viewImage(screenshot)"
              />
            </div>
          </div>

          <!-- 演示视频 -->
          <div v-if="workflow.demo_video_url" class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold mb-4">演示视频</h3>
            <video
              :src="workflow.demo_video_url"
              controls
              class="w-full rounded-lg"
            ></video>
          </div>

          <!-- 用户评价 -->
          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-lg font-semibold">用户评价</h3>
              <button
                v-if="canReview"
                @click="showReviewDialog"
                class="text-sm text-primary-600 hover:text-primary-900"
              >
                写评价
              </button>
            </div>

            <!-- 评分统计 -->
            <div class="mb-6 pb-6 border-b border-gray-200">
              <div class="flex items-center">
                <div class="text-center mr-8">
                  <div class="text-4xl font-bold text-gray-900">{{ workflow.rating }}</div>
                  <div class="flex items-center justify-center mt-1">
                    <svg v-for="i in 5" :key="i" class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  </div>
                  <div class="text-sm text-gray-500 mt-1">{{ workflow.review_count }} 条评价</div>
                </div>
                <div class="flex-1">
                  <div v-for="star in [5, 4, 3, 2, 1]" :key="star" class="flex items-center mb-1">
                    <span class="text-sm text-gray-600 w-8">{{ star }}星</span>
                    <div class="flex-1 mx-3 bg-gray-200 rounded-full h-2">
                      <div
                        :style="{ width: `${getStarPercentage(star)}%` }"
                        class="bg-yellow-400 h-2 rounded-full"
                      ></div>
                    </div>
                    <span class="text-sm text-gray-600 w-12">{{ getStarCount(star) }}</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- 评价列表 -->
            <div class="space-y-4">
              <div v-for="review in reviews" :key="review.id" class="border-b border-gray-200 pb-4 last:border-0">
                <div class="flex items-start">
                  <img
                    :src="review.user_avatar || '/default-avatar.png'"
                    :alt="review.user_name"
                    class="h-10 w-10 rounded-full mr-3"
                  />
                  <div class="flex-1">
                    <div class="flex justify-between items-start">
                      <div>
                        <p class="font-medium text-gray-900">{{ review.user_name }}</p>
                        <div class="flex items-center mt-1">
                          <svg v-for="i in 5" :key="i" :class="i <= review.rating ? 'text-yellow-400' : 'text-gray-300'" class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                          </svg>
                        </div>
                      </div>
                      <span class="text-sm text-gray-500">{{ formatDate(review.created_at) }}</span>
                    </div>
                    <p class="mt-2 text-gray-600">{{ review.comment }}</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- 加载更多 -->
            <div v-if="hasMoreReviews" class="text-center mt-4">
              <button
                @click="loadMoreReviews"
                class="text-sm text-primary-600 hover:text-primary-900"
              >
                加载更多评价
              </button>
            </div>
          </div>
        </div>

        <!-- 右侧购买面板 -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-lg shadow p-6 sticky top-24">
            <!-- 价格 -->
            <div class="mb-6">
              <div v-if="workflow.pricing_model === 'free'" class="text-2xl font-bold text-green-600">
                免费
              </div>
              <div v-else class="flex items-baseline gap-2">
                <span class="text-3xl font-bold text-primary-600">{{ workflow.milk_coin_price || 0 }}</span>
                <span class="text-lg text-gray-600">奶片</span>
                <span class="text-sm text-gray-500">{{ getPricingModelText(workflow.pricing_model) }}</span>
              </div>
            </div>

            <!-- 购买按钮 -->
            <button
              v-if="!isPurchased"
              @click="purchaseWorkflow"
              class="w-full px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors mb-6"
            >
              {{ workflow.pricing_model === 'free' ? '立即使用' : '立即购买' }}
            </button>
            <button
              v-else
              @click="useWorkflow"
              class="w-full px-6 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors mb-6"
            >
              开始使用
            </button>

          </div>
        </div>
      </div>

      <!-- 未找到 -->
      <div v-else class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">工作流不存在</h3>
        <p class="mt-1 text-sm text-gray-500">该工作流可能已下架或不存在</p>
        <div class="mt-6">
          <button
            @click="$router.push('/market')"
            class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700"
          >
            返回市场
          </button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue'
import { useRoute, useRouter } from 'vue-router'
import { showMessage } from '@/utils/message'
import { showConfirm, showPrompt, showAlert } from '@/utils/dialog'
import { getWorkflowDetail, purchaseWorkflow as purchaseWorkflowAPI, createReview } from '@/api/workflowMarket'

const route = useRoute()
const router = useRouter()

const workflowId = computed(() => parseInt(route.params.id))

// 当前用户ID（需要从store或路由获取）
const userId = ref(parseInt(localStorage.getItem('userId')) || 1)

// 工作流详情
const workflow = ref(null)
const loading = ref(true)

// 购买状态
const isPurchased = ref(false)
const hasTried = ref(false)
const canReview = ref(false)

// 评价
const reviews = ref([])
const reviewPage = ref(1)
const hasMoreReviews = ref(false)

// 加载工作流详情
const loadWorkflowDetail = async () => {
  loading.value = true

  try {
    const res = await getWorkflowDetail(workflowId.value)
    
    console.log('Workflow detail response:', res)
    
    if (res.code === 0) {
      workflow.value = res.data
      isPurchased.value = res.data.is_purchased || false
      canReview.value = res.data.can_review || false

      // 加载评价
      if (res.data.reviews) {
        reviews.value = res.data.reviews
      }
    }
  } catch (error) {
    console.error('加载失败:', error)
  } finally {
    loading.value = false
  }
}

// 加载评价
const loadReviews = async () => {
  // 评价已经在loadWorkflowDetail中加载
}

// 加载更多评价
const loadMoreReviews = () => {
  reviewPage.value++
  // TODO: 加载更多
}

// 获取评分百分比
const getStarPercentage = (star) => {
  if (!workflow.value?.rating_distribution) return 0
  const total = workflow.value.review_count
  const count = workflow.value.rating_distribution[star] || 0
  return total > 0 ? (count / total * 100).toFixed(1) : 0
}

// 获取评分数量
const getStarCount = (star) => {
  if (!workflow.value?.rating_distribution) return 0
  return workflow.value.rating_distribution[star] || 0
}

// 获取计费模式文本
const getPricingModelText = (model) => {
  const texts = {
    'one_time': '一次性',
    'subscription': '/月',
    'per_use': '/次'
  }
  return texts[model] || ''
}

// 格式化日期
const formatDate = (timestamp) => {
  const date = new Date(timestamp)
  return date.toLocaleDateString('zh-CN')
}

// 购买工作流
const purchaseWorkflow = async () => {
  const confirmed = await showConfirm(
    `确定购买工作流"${workflow.value.name}"吗？价格：${workflow.value.milk_coin_price} 奶片`,
    '确认购买'
  )
  
  if (!confirmed) return

  try {
    const res = await purchaseWorkflowAPI(workflow.value.id, 1)
    if (res.code === 0) {
      showMessage('购买成功', 'success')
      isPurchased.value = true
      // 重新加载详情以更新购买状态
      loadWorkflowDetail()
    }
  } catch (error) {
    console.error('购买失败:', error)
  }
}

// 试用工作流
const trialWorkflow = async () => {
  const confirmed = await showConfirm(
    `确定试用工作流"${workflow.value.name}"吗？试用次数：${workflow.value.trial_count}次`,
    '确认试用'
  )
  
  if (!confirmed) return
  
  // TODO: 调用试用API
  showMessage('试用成功', 'success')
  hasTried.value = true
}

// 使用工作流
const useWorkflow = () => {
  // TODO: 跳转到工作流执行页面
  router.push(`/workflows/${workflow.value.id}/execute`)
}

// 显示评价对话框
const showReviewDialog = async () => {
  const comment = await showPrompt('请输入您的评价', '评价工作流')
  
  if (!comment || comment.trim() === '') {
    showMessage('请输入评价内容', 'info')
    return
  }

  try {
    const res = await createReview(workflow.value.id, {
      rating: 5, // TODO: 可以添加评分选择
      comment: comment
    })

    if (res.code === 0) {
      showMessage('评价成功', 'success')
      // 重新加载详情以显示新评价
      loadWorkflowDetail()
    }
  } catch (error) {
    console.error('评价失败:', error)
  }
}

// 查看图片
const viewImage = (url) => {
  // TODO: 显示图片预览
  window.open(url, '_blank')
}

onMounted(() => {
  loadWorkflowDetail()
})
</script>