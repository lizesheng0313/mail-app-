{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "邮件管理",
  "mainBinaryName": "mail-desktop",
  "version": "1.1.0",
  "identifier": "com.mailservice.desktop",
  "build": {
    "frontendDist": "../../mail_frontend/dist",
    "devUrl": "http://localhost:9999",
    "beforeDevCommand": "cd ../mail_frontend && pnpm dev",
    "beforeBuildCommand": "cd ../mail_frontend && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8088 https://zjkdongao.cn https://*.zjkdongao.cn; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://zjkdongao.cn/desktop-updates/{{target}}-{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA3QkNDQkE2MDQ2QkRBQzIKUldUQzJtc0Vwc3U4QjliR2NZSHJzL2R3Y0NjT1k1dDZHQmw3alorWnUyNG9Ec2VCQ2lvR1VEdUQK"
    }
  }
}
